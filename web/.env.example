# Dashboard environment. For a systemd install the runtime vars come from
# ../config.env; for local `npm run dev`/`build` copy this to .env.local.
#
# Two kinds of vars live here:
#  - GPUGUARD_* are read at RUNTIME by the server (data.ts).
#  - NEXT_PUBLIC_* are inlined at BUILD time -- rebuild after changing them.

# Directory the monitor writes to (must match GPUGUARD_BASE in ../config.env).
GPUGUARD_BASE=/opt/gpumonitor

# Sampling interval of the collector, in seconds. The dashboard uses this to
# turn the in-progress hour's sample counts into hours, so it MUST match
# GPUGUARD_INTERVAL in ../config.env / the collector (default 10).
GPUGUARD_INTERVAL=10

# NOTE: the dashboard port is NOT read from here -- it's set by install.sh /
# run_dashboard.sh via GPUGUARD_PORT in ../config.env. `npm run dev`/`start`
# use the port in package.json (8090).

# Optional (BUILD-time, inlined by Next.js -- rebuild after changing):
# Heading shown in the dashboard (defaults to "GPUMonitor").
# NEXT_PUBLIC_TITLE=My GPU Cluster
# Display timezone (IANA name) for all chart ticks and the date/time pickers.
# Set to your cluster's timezone so times are unambiguous regardless of where a
# viewer's browser is; leave unset to use each viewer's own browser timezone.
# NEXT_PUBLIC_TZ=America/Los_Angeles
