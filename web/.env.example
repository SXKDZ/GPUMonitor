# Dashboard environment. For a systemd install these come from ../config.env;
# for local `npm run dev` copy this to .env.local and adjust.

# Directory the monitor writes to (must match GPUGUARD_BASE in ../config.env).
GPUGUARD_BASE=/opt/gpumonitor

# Port the dashboard listens on.
GPUGUARD_PORT=8090

# Optional: heading shown in the dashboard (defaults to "GPUMonitor").
# NEXT_PUBLIC_TITLE=My GPU Cluster

# Optional: display timezone (IANA name) for all chart ticks and the date/time
# range pickers. Set this to your cluster's timezone so times are unambiguous
# regardless of where a viewer's browser is. Leave unset to use each viewer's
# own browser timezone. NOTE: this is inlined at BUILD time -- rebuild after
# changing it (npm run build).
# NEXT_PUBLIC_TZ=America/Los_Angeles
