# GPUMonitor / GPUGuard configuration.
#
# Copy to `config.env` and edit for your cluster:
#     cp config.env.example config.env
#
# The installer (./install.sh) and the interim launchers source this file, and
# render the systemd units from it. Every value has a sensible default, so a
# minimal config.env only needs GPUGUARD_BASE.

# ---------------------------------------------------------------------------
# Paths / identity
# ---------------------------------------------------------------------------
# Shared directory where all hosts read/write data. On a multi-host cluster
# this MUST be a shared filesystem (NFS, etc.) visible on every host and on the
# dashboard host. On a single machine any writable path works.
GPUGUARD_BASE=/opt/gpumonitor

# User the monitor and dashboard run as (unprivileged). The guard always runs
# as root so it can terminate any user's process. If unset, the installer falls
# back to the invoking user (logname), then root.
GPUGUARD_USER=gpumonitor

# Host label used in data filenames and status (data/status/<host>.json). Leave
# unset to use this machine's short hostname -- only override if two hosts would
# otherwise collide on the same name.
# GPUGUARD_HOST=

# ---------------------------------------------------------------------------
# Sampling / stall detection (GPUMonitor + GPUGuard)
# ---------------------------------------------------------------------------
GPUGUARD_INTERVAL=10        # seconds between samples
GPUGUARD_WINDOW=300         # rolling window (s) used for the idle rule = "5 min"
GPUGUARD_IDLE_UTIL=5        # utilization % at/below which a sample counts as idle
GPUGUARD_IDLE_FRACTION=0.75 # fraction of idle samples in the window that flags a GPU
GPUGUARD_TERM_GRACE=15      # seconds between SIGTERM and SIGKILL (guard)
GPUGUARD_POLL=5             # seconds between guard status-file polls
GPUGUARD_STATUS_MAX_AGE=60  # guard ignores a status file older than this (s), so
                            # a dead/stalled monitor can't cause kills on stale data

# ---------------------------------------------------------------------------
# Data retention (prune)
# ---------------------------------------------------------------------------
# Delete rollups/events older than this many days. Used by bin/prune_data.py
# and the optional gpu-prune.timer (install with: sudo ./install.sh prune).
GPUGUARD_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Dashboard (Next.js)
# ---------------------------------------------------------------------------
GPUGUARD_PORT=8090          # port the dashboard listens on (used by install.sh /
                            # run_dashboard.sh; the web code itself does not read it)
# Absolute path to the `node` bin directory (dirname of `which node`). Needed
# because systemd units have no login shell. Leave blank to auto-detect at
# install time.
GPUGUARD_NODE_BIN=

# Dashboard display, inlined by Next.js at BUILD time (NOT runtime). To change
# these you must set them in the build environment and rebuild -- putting them
# only in this file for the systemd runtime has no effect. Easiest: also place
# them in web/.env.local, then `npm --prefix web run build`.
#   NEXT_PUBLIC_TITLE=My GPU Cluster       # heading (default "GPUMonitor")
#   NEXT_PUBLIC_TZ=America/Los_Angeles      # display timezone for charts/pickers
